---
import "@fontsource-variable/jetbrains-mono";
import "@fontsource-variable/jetbrains-mono/wght-italic.css";

interface Props {
	class: string;
}
const className = Astro.props.class;
---
<div data-pagefind-body class={`prose dark:prose-invert prose-base !max-w-none custom-md ${className}`}>
    <!--<div class="prose dark:prose-invert max-w-none custom-md">-->
    <!--<div class="max-w-none custom-md">-->
    <slot/>
</div>

<style is:global>
#wiki-tooltip {
    position: absolute;
    z-index: 9999;
    max-width: 320px;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
    pointer-events: none;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.15s ease, transform 0.15s ease;
    background: var(--wiki-tooltip-bg, #fff);
    border: 1px solid var(--wiki-tooltip-border, rgba(0,0,0,0.1));
    color: var(--wiki-tooltip-text, #1a1a1a);

    &.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .wiki-tooltip-title {
        font-weight: 600;
        font-size: 0.9rem;
        line-height: 1.4;
        margin-bottom: 0.3rem;
    }

    .wiki-tooltip-desc {
        font-size: 0.8rem;
        line-height: 1.5;
        opacity: 0.75;
    }

    .wiki-tooltip-badge {
        display: inline-block;
        font-size: 0.7rem;
        padding: 0.1rem 0.4rem;
        border-radius: 0.25rem;
        margin-bottom: 0.3rem;
        background: var(--primary);
        color: white;
        opacity: 0.85;
    }
}

:root {
    --wiki-tooltip-bg: #ffffff;
    --wiki-tooltip-border: rgba(0, 0, 0, 0.1);
    --wiki-tooltip-text: #1a1a1a;
}

:root.dark {
    --wiki-tooltip-bg: #1e2028;
    --wiki-tooltip-border: rgba(255, 255, 255, 0.1);
    --wiki-tooltip-text: #e8eaf0;
}
</style>

<script>
/* ── Wiki Link Hover Tooltip ─────────────────────────────────────── */

let postIndex: Record<string, { title: string; description: string; type: "post" | "wiki" }> | null = null;
let tooltipEl: HTMLElement | null = null;
let showTimer: ReturnType<typeof setTimeout> | null = null;
let hideTimer: ReturnType<typeof setTimeout> | null = null;

async function fetchPostIndex() {
    if (postIndex) return postIndex;
    try {
        const res = await fetch("/wiki-preview.json");
        postIndex = await res.json();
    } catch {
        postIndex = {};
    }
    return postIndex;
}

function getTooltip(): HTMLElement {
    if (!tooltipEl) {
        tooltipEl = document.createElement("div");
        tooltipEl.id = "wiki-tooltip";
        tooltipEl.setAttribute("role", "tooltip");
        document.body.appendChild(tooltipEl);
    }
    return tooltipEl;
}

async function showTooltip(link: HTMLElement) {
    const slug = link.dataset.wikiSlug;
    const type = link.dataset.wikiType ?? "post";
    if (!slug) return;

    const index = await fetchPostIndex();
    const lookupKey = type === "wiki" ? `wiki:${slug}` : slug;
    const post = index?.[lookupKey];
    if (!post?.title) return;

    const el = getTooltip();
    const badge = type === "wiki" ? `<div class="wiki-tooltip-badge">Wiki</div>` : "";
    el.innerHTML =
        badge +
        `<div class="wiki-tooltip-title">${post.title}</div>` +
        (post.description
            ? `<div class="wiki-tooltip-desc">${post.description}</div>`
            : "");

    // Position: below the link by default
    const rect = link.getBoundingClientRect();
    const scrollX = window.scrollX;
    const scrollY = window.scrollY;

    el.style.left = `${rect.left + scrollX}px`;
    el.style.top = `${rect.bottom + scrollY + 8}px`;
    el.classList.add("visible");

    // Adjust horizontal overflow
    const tipRect = el.getBoundingClientRect();
    if (tipRect.right > window.innerWidth - 8) {
        el.style.left = `${window.innerWidth - tipRect.width - 8 + scrollX}px`;
    }
    // Flip above if too close to bottom
    if (tipRect.bottom > window.innerHeight - 8) {
        el.style.top = `${rect.top + scrollY - tipRect.height - 8}px`;
    }
}

function hideTooltip() {
    tooltipEl?.classList.remove("visible");
}

// Event delegation – works across Swup page transitions
document.addEventListener("mouseover", (e) => {
    const link = (e.target as Element).closest<HTMLElement>("a.wiki-link");
    if (!link) return;
    if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
    showTimer = setTimeout(() => showTooltip(link), 200);
});

document.addEventListener("mouseout", (e) => {
    const link = (e.target as Element).closest<HTMLElement>("a.wiki-link");
    if (!link) return;
    if (showTimer) { clearTimeout(showTimer); showTimer = null; }
    hideTimer = setTimeout(hideTooltip, 100);
});
/* ─────────────────────────────────────────────────────────────────── */

document.addEventListener("click", function (e: MouseEvent) {
    const target = e.target as Element | null;
    if (target && target.classList.contains("copy-btn")) {
        const preEle = target.closest("pre");
        const codeEle = preEle?.querySelector("code");
        const code = Array.from(codeEle?.querySelectorAll(".code:not(summary *)") ?? [])
            .map(el => el.textContent)
            .map(t => t === "\n" ? "" : t)
            .join("\n");
        navigator.clipboard.writeText(code);

        const timeoutId = target.getAttribute("data-timeout-id");
        if (timeoutId) {
            clearTimeout(parseInt(timeoutId));
        }

        target.classList.add("success");

        // 设置新的timeout并保存ID到按钮的自定义属性中
        const newTimeoutId = setTimeout(() => {
            target.classList.remove("success");
        }, 1000);

        target.setAttribute("data-timeout-id", newTimeoutId.toString());
    }
});
</script>
